model LibraryYear_ListAV {
  libraryyear_id Int
  listav_id      Int

  // User selection fields
  is_selected  Boolean?  @default(false) // User has selected this AV entry
  custom_count Int? // User's custom count (overrides default)
  updated_at   DateTime? @default(now()) // Last update time

  Library_Year Library_Year @relation(fields: [libraryyear_id], references: [id])
  List_AV      List_AV      @relation(fields: [listav_id], references: [id])

  @@id([libraryyear_id, listav_id])
}

